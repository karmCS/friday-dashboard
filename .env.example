# Friday Dashboard — environment variables
#
# PUBLIC REPO: this file lists secret NAMES only, never values.
# Copy to `.env` on VM1 and fill in real values there. `.env` is gitignored.
# Real values are mirrored to Vaultwarden as the source of truth.

# --- Web analytics (Umami) ---
# v3 uses credential auth (no static API keys in UI); JWT cached in memory.
UMAMI_BASE_URL=
UMAMI_USERNAME=
UMAMI_PASSWORD=

# --- Uptime (Uptime Kuma) ---
KUMA_BASE_URL=
KUMA_TOKEN=

# --- Infra metrics (Beszel) ---
# PocketBase tokens expire — using credential auth (cached JWT, auto-refreshes).
BESZEL_BASE_URL=
BESZEL_USERNAME=
BESZEL_PASSWORD=

# --- Deficit app data (Supabase, service_role) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Deficit funnel (PostHog) ---
POSTHOG_HOST=
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=

# --- Deficit crashes (Sentry) ---
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Deficit revenue (RevenueCat, optional for live MRR) ---
REVENUECAT_SECRET_KEY=

# --- Cardio (Strava OAuth) ---
# STRAVA_VERIFY_TOKEN: arbitrary string you choose; must match the webhook subscription.
STRAVA_VERIFY_TOKEN=
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# --- Endpoint auth tokens ---
# Bearer token for headless Claude Code to fetch /api/snapshot
SNAPSHOT_TOKEN=
# Bearer token for the iOS Shortcut steps bridge (POST /api/fitness/steps)
STEPS_TOKEN=
# Bearer token for the iOS Shortcut bodyweight bridge (POST /api/fitness/bodyweight)
BODYWEIGHT_TOKEN=
