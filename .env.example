# Friday Dashboard — environment variables
#
# PUBLIC REPO: this file lists secret NAMES only, never values.
# Copy to `.env` on VM1 and fill in real values there. `.env` is gitignored.
# Real values are mirrored to Vaultwarden as the source of truth.

# --- Web analytics (Umami) ---
# v3 uses credential auth (no static API keys in UI); JWT cached in memory.
UMAMI_BASE_URL=
UMAMI_USERNAME=
UMAMI_PASSWORD=

# --- Uptime (Uptime Kuma) ---
KUMA_BASE_URL=
KUMA_TOKEN=

# --- Infra metrics (Beszel) ---
# PocketBase tokens expire — using credential auth (cached JWT, auto-refreshes).
BESZEL_BASE_URL=
BESZEL_USERNAME=
BESZEL_PASSWORD=

# --- Deficit app data (Supabase, service_role) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Deficit funnel (PostHog) ---
POSTHOG_HOST=
POSTHOG_PROJECT_ID=
POSTHOG_PERSONAL_API_KEY=

# --- Deficit crashes (Sentry) ---
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Deficit revenue (RevenueCat, optional for live MRR) ---
REVENUECAT_SECRET_KEY=

# --- Cardio (Strava OAuth) ---
# STRAVA_VERIFY_TOKEN: arbitrary string you choose; must match the webhook subscription.
STRAVA_VERIFY_TOKEN=
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# --- Dashboard login (email + password gate, single operator) ---
# The one identity allowed to sign in. Password is stored hashed, never plaintext:
#   node scripts/hash-password.mjs 'your-password'   → prints the AUTH_PASSWORD_HASH line.
AUTH_EMAIL=
AUTH_PASSWORD_HASH=
# 32+ random bytes that sign the session cookie. Generate:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# REQUIRED — if unset, every request is locked out (fail closed).
AUTH_SESSION_SECRET=

# --- Bot challenge (Cloudflare Turnstile) ---
# From Cloudflare dashboard → Turnstile. Leave BOTH blank to use Cloudflare's always-pass TEST
# keys (login works, but NO real bot protection until you set production keys).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Endpoint auth tokens ---
# Bearer token for headless Claude Code to fetch /api/snapshot
SNAPSHOT_TOKEN=
# Bearer token for the iOS Shortcut steps bridge (POST /api/fitness/steps)
STEPS_TOKEN=
# Bearer token for the iOS Shortcut bodyweight bridge (POST /api/fitness/bodyweight)
BODYWEIGHT_TOKEN=
